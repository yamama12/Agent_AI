# Database configuration (MySQL 9.x)
DB_HOST="HOST"
DB_USER="USER"
DB_PASSWORD="PASSWORD"
DB_NAME="NAME"
DB_PORT=3306
DB_USE_PURE=True
DB_AUTH_PLUGIN='mysql_native_password'
DB_CHARSET='utf8mb4'
DB_AUTOCOMMIT=True
DB_CONNECTION_TIMEOUT=30

# API Keys (Google Gemini API Key)
GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE